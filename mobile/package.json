{
  "name": "pile-mobile",
  "version": "0.1.0",
  "private": true,
  "description": "Pile iOS/Android app (Ionic React + Capacitor)",
  "scripts": {
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "cap:init": "cap init Pile com.pile.app --web-dir=dist --npm-client=npm --yes",
    "cap:add:ios": "cap add ios",
    "cap:sync": "cap sync",
    "ios:build": "npm run build && cap copy ios && cap sync ios",
    "ios:open": "cap open ios"
  },
  "dependencies": {
    "@capacitor/app": "^6.0.0",
    "@capacitor/core": "^6.0.0",
    "@capacitor/device": "^6.0.0",
    "@capacitor/filesystem": "^6.0.0",
    "@capacitor/haptics": "^6.0.0",
    "@capacitor/ios": "^6.0.0",
    "@capacitor/keyboard": "^6.0.0",
    "@capacitor/preferences": "^6.0.0",
    "@capacitor/share": "^6.0.0",
    "@capacitor/status-bar": "^6.0.0",
    "@ionic/react": "^8.0.0",
    "@ionic/react-router": "^8.0.0",
    "ionicons": "^7.2.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.23.1",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.0.0",
    "@types/react": "^18.2.21",
    "@types/react-dom": "^18.2.7",
    "typescript": "^5.2.2",
    "vite": "^5.4.0"
  }
}

