{
  "expo": {
    "name": "Pile",
    "slug": "pile-mobile",
    "scheme": "pile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "pile.un.ms.mobile"
    },
    "android": {
      "package": "pile.un.ms.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-secure-store",
      "expo-file-system",
      [
        "react-native-reanimated",
        { "allowDangerousSilentJSONParsing": true }
      ]
    ]
  }
}